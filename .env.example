NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Server-only (never commit real values)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxnZXp1ZmdhZWVxZmJ3Y2Fpc2phIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MDE1NTUzNCwiZXhwIjoyMDk1NzMxNTM0fQ.5jGpNYeTSQMRNF5NXfLsJ0Uy1IW6F5PD2MwY2_ibWWg
SESSION_SECRET=generate_at_least_32_random_characters_here

# Nightly analysis — Gemini API (free tier: ~1 call/day is fine)
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
# Fallback if primary hits 503 (comma-separated; default: gemini-2.5-flash-lite)
# GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite

# Midnight cron auth (Vercel sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=generate_a_long_random_string_here

# IANA timezone for midnight lock + analysis run_date (default: America/New_York)
# Adjust vercel.json cron UTC hour to match your local midnight
PLUSULTRA_TIMEZONE=America/New_York
